# dNLab Docker distribution settings.
# Copy to `.env` and change all secrets before starting the stack.

# Product version and image selection. All dNLab images use this version.
DNLAB_VERSION=0.1.2

# Image prefixes. Use the shown values for GHCR releases; override both for mirrors or local registries.
DNLAB_IMAGE_PREFIX=ghcr.io/scaci/
DNLAB_RUNTIME_IMAGE_PREFIX=ghcr.io/scaci/dnlab-

# Fresh-install auth DB settings.
# Copy to `.env` and change POSTGRES_PASSWORD before starting the stack.
POSTGRES_DB=dnlab_auth
POSTGRES_USER=dnlab_gui
POSTGRES_PASSWORD=change-me-generate-a-random-value

# Public TLS proxy settings. TLS is always enabled; self-signed certs are fine for local tests.
DNLAB_PROXY_SERVER_NAME=localhost
DNLAB_PROXY_HTTP_PORT=80
DNLAB_PROXY_HTTPS_PORT=443
# For Certbot/Let's Encrypt, mount `/etc/letsencrypt` and point the cert/key
# paths at `/etc/ssl/dnlab/live/<cert-name>/...` inside the proxy container.
# DNLAB_PROXY_TLS_DIR=/etc/letsencrypt
# DNLAB_PROXY_CERT_FILE=/etc/ssl/dnlab/live/dnlab.example.com/fullchain.pem
# DNLAB_PROXY_CERT_KEY_FILE=/etc/ssl/dnlab/live/dnlab.example.com/privkey.pem
# DNLAB_PROXY_ACME_DIR=/var/www/acme-challenge
# DNLAB_PROXY_WEBUI_SUFFIX and DNLABGUI_WEBUI_HOST_SUFFIX are derived from DNLAB_PROXY_SERVER_NAME.
# DNLABGUI_ALLOWED_ORIGINS=https://localhost

# Optional host-side topologies directory.
# DNLAB_TOPOLOGIES_DIR=/root/dnlab-topologies

# Optional host-side persistence/log/workspace directories.
# DNLAB_PERSIST_ROOT=/var/lib/docker/dnlab-backups
# DNLAB_LOG_ROOT=/var/log/dnlab
# DNLAB_IMAGE_BUILD_WORKSPACE=/var/lib/dnlab-image-build
# DNLAB_VRNETLAB_DIR=/opt/vrnetlab
# DNLAB_TMP_DIR=/tmp
# DNLAB_CONTAINERLAB_BIN=/usr/bin/containerlab

# Optional first-admin bootstrap values. Prefer exporting these only for the
# one seed command instead of keeping a real password in `.env`.
# DNLABGUI_BOOTSTRAP_ADMIN_USERNAME=admin
# DNLABGUI_BOOTSTRAP_ADMIN_PASSWORD=change-me
