#!/usr/bin/env python3
"""Small stdlib-only client for dNLab runtime relay."""

from __future__ import annotations

import os
import select
import shlex
import signal
import socket
import sys
import termios
import tty

READ_SIZE = 4096


def _usage() -> int:
    print(
        "Usage:\n"
        "  vd-relay-client connect <host> <port> <api_key> <container>\n"
        "  vd-relay-client log <host> <port> <api_key> <container> <tail> <follow>",
        file=sys.stderr,
    )
    return 2


def _request_line(action: str, api_key: str, container: str, *extra: str) -> bytes:
    parts = [action, api_key, container, *extra]
    return (" ".join(shlex.quote(part) for part in parts) + "\n").encode()


def _open(host: str, port: str, action: str, api_key: str, container: str, *extra: str):
    sock = socket.create_connection((host, int(port)))
    sock.sendall(_request_line(action, api_key, container, *extra))
    return sock


def _copy_socket_to_stdout(sock: socket.socket) -> int:
    out = sys.stdout.buffer
    while True:
        data = sock.recv(READ_SIZE)
        if not data:
            return 0
        out.write(data)
        out.flush()


def _read_status(sock_file) -> str:
    return sock_file.readline().decode(errors="replace").rstrip("\n")


def _run_log(argv: list[str]) -> int:
    if len(argv) != 6:
        return _usage()
    host, port, api_key, container, tail, follow = argv
    with _open(host, port, "LOG", api_key, container, tail, follow) as sock:
        with sock.makefile("rb", buffering=0) as sock_file:
            status = _read_status(sock_file)
            if status != "OK":
                print(status or "ERR relay closed before status", file=sys.stderr)
                return 1
            out = sys.stdout.buffer
            while True:
                data = sock_file.read(READ_SIZE)
                if not data:
                    return 0
                out.write(data)
                out.flush()


def _run_connect(argv: list[str]) -> int:
    if len(argv) != 4:
        return _usage()
    host, port, api_key, container = argv
    sock = _open(host, port, "CONNECT", api_key, container)
    old_term = None
    stdin_fd = sys.stdin.fileno()
    stdout = sys.stdout.buffer
    stdin_open = True

    def _restore(*_):
        if old_term is not None:
            termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_term)

    try:
        if sys.stdin.isatty():
            old_term = termios.tcgetattr(stdin_fd)
            tty.setraw(stdin_fd)
            signal.signal(signal.SIGTERM, _restore)
            signal.signal(signal.SIGINT, _restore)

        while True:
            readers = [sock]
            if stdin_open:
                readers.append(stdin_fd)
            readable, _, _ = select.select(readers, [], [])
            if sock in readable:
                data = sock.recv(READ_SIZE)
                if not data:
                    return 0
                stdout.write(data)
                stdout.flush()
            if stdin_fd in readable:
                data = os.read(stdin_fd, READ_SIZE)
                if not data:
                    try:
                        sock.shutdown(socket.SHUT_WR)
                    except OSError:
                        pass
                    stdin_open = False
                    continue
                sock.sendall(data)
    finally:
        _restore()
        sock.close()


def main() -> int:
    if len(sys.argv) < 2:
        return _usage()
    cmd = sys.argv[1]
    if cmd == "connect":
        return _run_connect(sys.argv[2:])
    if cmd == "log":
        return _run_log(sys.argv[2:])
    return _usage()


if __name__ == "__main__":
    raise SystemExit(main())
